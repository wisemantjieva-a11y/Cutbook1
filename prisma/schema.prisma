generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SHOP_OWNER
  BARBER
  CUSTOMER
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum SubscriptionStatus {
  NONE
  UNPAID
  PAID
}

model User {
  id                    String             @id @default(cuid())
  email                 String             @unique
  phone                 String?            @unique
  name                  String
  passwordHash          String
  role                  Role               @default(CUSTOMER)
  status                UserStatus         @default(ACTIVE)
  subscriptionStatus    SubscriptionStatus @default(NONE)
  subscriptionPaidUntil DateTime?
  approvedAt            DateTime?
  suspendedAt           DateTime?
  suspendReason         String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  shops            Shop[]         @relation("ShopOwner")
  barberProfile    BarberProfile?
  appointments     Appointment[]  @relation("CustomerAppointments")
  reviewsGiven     Review[]       @relation("ReviewAuthor")
}

model Shop {
  id          String   @id @default(cuid())
  name        String
  description String?
  address     String?
  phone       String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner        User              @relation("ShopOwner", fields: [ownerId], references: [id])
  barbers      BarberProfile[]
  services     Service[]
  appointments Appointment[]
  reviews      Review[]
  joinRequests ShopJoinRequest[]
}

model BarberProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  shopId         String?
  bio            String?
  specialties    String[]
  isMobileBarber Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id])
  shop         Shop?             @relation(fields: [shopId], references: [id])
  services     Service[]
  appointments Appointment[]
  joinRequests ShopJoinRequest[]
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  durationMin Int
  shopId      String?
  barberId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop         Shop?           @relation(fields: [shopId], references: [id])
  barber       BarberProfile?  @relation(fields: [barberId], references: [id])
  appointments Appointment[]
}

model AvailabilityHour {
  id        String   @id @default(cuid())
  barberId  String
  dayOfWeek Int
  startTime String
  endTime   String
  createdAt DateTime @default(now())
}

model Appointment {
  id         String   @id @default(cuid())
  customerId String
  barberId   String
  shopId     String?
  serviceId  String
  startTime  DateTime
  endTime    DateTime
  status     String   @default("PENDING")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer  User          @relation("CustomerAppointments", fields: [customerId], references: [id])
  barber    BarberProfile @relation(fields: [barberId], references: [id])
  shop      Shop?         @relation(fields: [shopId], references: [id])
  service   Service       @relation(fields: [serviceId], references: [id])
  payment   Payment?
  review    Review?
}

model Payment {
  id            String   @id @default(cuid())
  appointmentId String   @unique
  amount        Float
  currency      String   @default("NAD")
  status        String   @default("PENDING")
  method        String?
  reference     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model Review {
  id            String   @id @default(cuid())
  authorId      String
  shopId        String?
  appointmentId String?  @unique
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  author      User         @relation("ReviewAuthor", fields: [authorId], references: [id])
  shop        Shop?        @relation(fields: [shopId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
}

model ShopJoinRequest {
  id        String   @id @default(cuid())
  barberId  String
  shopId    String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  barber BarberProfile @relation(fields: [barberId], references: [id])
  shop   Shop          @relation(fields: [shopId], references: [id])
}
