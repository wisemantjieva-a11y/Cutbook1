# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@localhost:5432/cutbook?schema=public

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
NODE_ENV=development

# ── Stripe (payments) ───────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ── Africa's Talking (SMS reminders / confirmations) ────────────────────────
# Get these from https://account.africastalking.com
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=CutBook

# ── Cron (day-of SMS reminders) ─────────────────────────────────────────────
# Set this in your hosting provider's env vars; Vercel Cron sends it automatically
# as an Authorization: Bearer header when this var is present.
CRON_SECRET=replace_with_a_random_string

# ── Object storage (shop/barber photo uploads) ──────────────────────────────
# Works with any S3-compatible provider: AWS S3, Cloudflare R2, Backblaze B2.
# Leave S3_ENDPOINT unset for real AWS S3; set it for R2/B2/MinIO.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=cutbook-uploads
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
# Public base URL your uploaded files are served from (bucket public URL or CDN in front of it)
S3_PUBLIC_BASE_URL=https://cutbook-uploads.example.com
